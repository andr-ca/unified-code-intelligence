# =============================================================================
# UCI configuration (sanitized sample). Copy to the target repo's `.uci/.env`
# and edit as needed. NEVER commit a real .env with secrets. All keys are UCI_*
# and optional — the default local-lite profile needs NONE of them.
# =============================================================================

# Which repository to index (defaults to the current directory).
# UCI_REPO_PATH=/path/to/repo

# -----------------------------------------------------------------------------
# Profile selects backend defaults: local-lite | local-pro | cloud
# -----------------------------------------------------------------------------
UCI_PROFILE=local-lite

# Ignore behavior
UCI_USE_GITIGNORE=1
UCI_INDEX_ALL_TEXT=0

# Retrieval fusion weights (graph-first defaults) + RRF constant
# UCI_WEIGHT_SYMBOL=1.4
# UCI_WEIGHT_KEYWORD=1.0
# UCI_WEIGHT_SEMANTIC=1.0
# UCI_WEIGHT_GRAPH=0.8
# UCI_WEIGHT_PROXIMITY=0.4
# UCI_WEIGHT_CHURN=0.3
# UCI_RRF_K=60

# Gap registry: extra name prefixes treated as external (not "missing"), comma-separated.
# Defaults already include mainframe system prefixes (DFH, DSN, CEE, DFS, IGZ, IDMS, SYSIBM).
# UCI_GAP_EXTERNAL_PREFIXES=ACME,LEGACY


# =============================================================================
# Profile 1 — local-lite (DEFAULT): no Docker, no services, no keys.
#   SQLite + in-memory graph + hash embeddings. Everything above is enough.
# =============================================================================
# UCI_GRAPH_BACKEND=sqlite
# UCI_VECTOR_BACKEND=sqlite
# UCI_METADATA_BACKEND=sqlite
# UCI_EMBEDDING_PROVIDER=local        # 'local' (hash) or 'noop' (disable semantic)


# =============================================================================
# Profile 2 — local-pro: Docker services via docker-compose.local-pro.yml
#   Memgraph (graph) + Qdrant (vectors) + Ollama (local embeddings). No cloud keys.
# =============================================================================
# UCI_PROFILE=local-pro
# UCI_GRAPH_BACKEND=memgraph
# UCI_VECTOR_BACKEND=qdrant
# UCI_METADATA_BACKEND=sqlite
# UCI_EMBEDDING_PROVIDER=ollama
# UCI_MEMGRAPH_URL=bolt://localhost:7687
# UCI_QDRANT_URL=http://localhost:6333
# UCI_OLLAMA_BASE_URL=http://localhost:11434
# UCI_OLLAMA_MODEL=nomic-embed-text
# UCI_EMBEDDING_DIM=768


# =============================================================================
# Profile 3 — cloud / dev-team: Postgres + Neo4j/Memgraph + Qdrant + cloud LLM.
#   Provide credentials via your secrets manager, NOT in a committed file.
# =============================================================================
# UCI_PROFILE=cloud
# UCI_GRAPH_BACKEND=neo4j
# UCI_VECTOR_BACKEND=qdrant
# UCI_METADATA_BACKEND=postgres
# UCI_EMBEDDING_PROVIDER=openai
# UCI_NEO4J_URL=bolt://neo4j:7687
# UCI_NEO4J_USER=neo4j
# UCI_NEO4J_PASSWORD=change-me                # <-- inject from a secret store
# UCI_QDRANT_URL=http://qdrant:6333
# UCI_POSTGRES_DSN=postgresql://user:pass@postgres:5432/uci   # <-- from a secret store
# UCI_OPENAI_API_KEY=sk-your-key-here         # <-- from a secret store
# UCI_OPENAI_BASE_URL=https://api.openai.com/v1
# UCI_OPENAI_EMBED_MODEL=text-embedding-3-small
# UCI_EMBEDDING_DIM=1536

# --- optional LLM enrichment (docs/llm-enrichment.md) -------------------
# Protocol: ollama (local, default) | openai (any OpenAI-compatible server) | anthropic | freellm
# UCI_LLM_PROTOCOL=ollama
# UCI_LLM_URL=http://localhost:11434       # or https://api.openai.com/v1, a vLLM/LM Studio URL, ...
# UCI_LLM_MODEL=qwen2.5-coder:7b           # or gpt-4o-mini, claude-haiku-4-5-20251001, ...
# UCI_LLM_API_KEY=                         # optional; required by cloud providers
# UCI_LLM_TIMEOUT=60
# UCI_LLM_MAX_TOKENS=700
#
# freellm — local OpenAI-compatible gateway on :3001 that auto-selects the best model:
# UCI_LLM_PROTOCOL=freellm
# UCI_LLM_URL=http://localhost:3001/v1     # default when protocol=freellm
# UCI_LLM_MODEL=                           # leave empty -> freellm picks the best model
# UCI_LLM_API_KEY=                         # required by freellm; set your key here (never commit real keys)
