# UCI local configuration — copy to .env and fill in. Never commit the real .env.
#
# --- Optional LLM enrichment (docs/llm-enrichment.md) --------------------------------
# Protocol: ollama | openai | anthropic | freellm
#   ollama  -> local, keyless (default). Set UCI_LLM_MODEL to an installed model.
#   openai  -> OpenAI or any OpenAI-compatible server (vLLM, LM Studio, LiteLLM, gateways).
#   anthropic -> Anthropic Messages API.
#   freellm -> a locally-hosted OpenAI-compatible gateway (localhost only) fronting many models.
UCI_LLM_PROTOCOL=ollama
UCI_LLM_URL=
UCI_LLM_MODEL=
UCI_LLM_API_KEY=            # required for openai/anthropic/freellm; leave blank for ollama
UCI_LLM_TIMEOUT=60
UCI_LLM_MAX_TOKENS=700

# LLM call logging (docs/llm-enrichment.md §5): append every call as JSONL for offline analysis.
# Empty -> <repo>/.uci/llm-calls.jsonl. Set to "off" to disable, or a path to redirect.
UCI_LLM_LOG=

# --- Optional LSP / SCIP edge oracles (docs/lsp-refactoring-recommendations.md) -------
# Language servers are DETECTED, not bundled: point UCI at a server you provide, and
# `uci enrich --lsp <lang>` verifies/prunes speculative call edges. Missing = skipped, never fatal.
# Launch command per language (shell-split). Leave blank to disable that language.
#   COBOL: Eclipse Che4z COBOL Language Support (Broadcom, Apache-2.0), run headless.
UCI_LSP_COBOL_CMD=              # e.g. cobol-language-support   (a wrapper/jar launcher on PATH)
UCI_LSP_COBOL_COPYBOOKS=        # comma/os-sep list of copybook search dirs, e.g. cpy,copybooks
UCI_LSP_PYTHON_CMD=             # e.g. pyright-langserver --stdio
UCI_LSP_TYPESCRIPT_CMD=         # e.g. typescript-language-server --stdio
# SCIP has no env var — pass the index path directly: `uci enrich --scip path/to/index.scip`

# --- Documentation ingestion (docs/documentation-ingestion.md) -----------------------
# Docs (.md/.rst/.adoc/.txt/.html; PDF/DOCX with `pip install -e ".[docs]"`) are indexed
# by default into the graph as DOC_SECTION entities linked to the code they describe.
UCI_INDEX_DOCS=1
UCI_WEIGHT_DOC=0.8          # ranking multiplier for doc hits (docs must not swamp code)
UCI_DOC_MAX_BYTES=10000000  # size cap for converter formats (PDF/DOCX) only
